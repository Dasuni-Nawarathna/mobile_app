# Copy this file to `.env` in the same folder, then restart Expo (`npx expo start`).
# Only variables prefixed EXPO_PUBLIC_ are exposed to the app bundle.

# Express API (`backend/`) — use the port shown when you run `npm run dev` there.
# Android emulator default in code is 10.0.2.2:5000; web/iOS simulator use 127.0.0.1.
EXPO_PUBLIC_API_URL=http://127.0.0.1:5000
